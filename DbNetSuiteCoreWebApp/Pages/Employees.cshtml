@page
@using DbNetSuiteCore.Models
@{
    Layout = "/pages/shared/_Layout.cshtml";
}
@using DbNetSuiteCore.Models.Configuration
@using DbNetSuiteCore.Enums
<div class="p-4">
    <h3>Employees</h3>
    @await Component.InvokeAsync("DbNetGrid", new DbNetGridConfiguration()
{
    Id = "EmployeesGrid",
    ConnectionString = "Chinook",
    DataProvider = DbNetSuiteCore.Services.DataProvider.SQLite,
    TableName = "Employees",
    Columns = new List<GridColumn>()
    {
          new GridColumn("EmployeeId"),
          new GridColumn("LastName"),
          new GridColumn("FirstName"),
          new GridColumn("Title"),
          new GridColumn("ReportsTo") { Label = "Line Manager", Lookup = "select employeeId, LastName || ', ' || FirstName from employees" },
          new GridColumn("BirthDate") { Format = "d"},
          new GridColumn("HireDate") { Format = "d"},
          new GridColumn("Address"),
          new GridColumn("City"),
          new GridColumn("State"),
          new GridColumn("Country"),
          new GridColumn("PostalCode"),
          new GridColumn("Phone"),
          new GridColumn("Fax"),
          new GridColumn("Email") { StandardFormat = Format.Email},
    }
})
</div>
