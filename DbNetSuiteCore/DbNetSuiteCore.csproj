<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>netcoreapp2.2</TargetFramework>
    <TypeScriptToolsVersion>3.2</TypeScriptToolsVersion>
  </PropertyGroup>

  <ItemGroup>
    <None Remove="JavaScript\DbNetSuite.js" />
    <None Remove="JavaScript\jquery.3.4.1.min.js" />
    <None Remove="JavaScript\notify.min.js" />
    <None Remove="TypeScript\Interfaces.ts" />
    <None Remove="Views\Shared\Components\DbNetGrid\Default.cshtml" />
    <None Remove="Views\Shared\DbNetGrid_Toolbar.cshtml" />
  </ItemGroup>

  <ItemGroup>
    <EmbeddedResource Include="JavaScript\DbNetSuite.js" />
    <EmbeddedResource Include="JavaScript\jquery.3.4.1.min.js" />
    <EmbeddedResource Include="JavaScript\notify.min.js" />
    <EmbeddedResource Include="Views\Shared\Components\DbNetGrid\Default.cshtml" />
    <EmbeddedResource Include="Views\Shared\DbNetGrid_Toolbar.cshtml" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.AspNetCore" Version="2.2.0" />
    <PackageReference Include="Microsoft.AspNetCore.Mvc" Version="2.2.0" />
    <PackageReference Include="Microsoft.Extensions.FileProviders.Embedded" Version="2.2.0" />
    <PackageReference Include="Microsoft.TypeScript.MSBuild" Version="3.5.2">
      <PrivateAssets>all</PrivateAssets>
      <IncludeAssets>runtime; build; native; contentfiles; analyzers</IncludeAssets>
    </PackageReference>
    <PackageReference Include="System.Configuration.ConfigurationManager" Version="4.6.0-preview6.19303.8" />
    <PackageReference Include="System.Data.Odbc" Version="4.6.0-preview6.19303.8" />
    <PackageReference Include="System.Data.OleDb" Version="4.6.0-preview6.19303.8" />
    <PackageReference Include="System.Data.SqlClient" Version="4.7.0-preview6.19303.8" />
  </ItemGroup>

  <ItemGroup>
    <Folder Include="Models\Components\" />
  </ItemGroup>

  <PropertyGroup Condition="'$(Configuration)' == 'Debug'">
    <TypeScriptTarget>ES5</TypeScriptTarget>
    <TypeScriptJSXEmit>None</TypeScriptJSXEmit>
    <TypeScriptModuleKind />
    <TypeScriptCompileOnSaveEnabled>True</TypeScriptCompileOnSaveEnabled>
    <TypeScriptNoImplicitAny>False</TypeScriptNoImplicitAny>
    <TypeScriptRemoveComments>False</TypeScriptRemoveComments>
    <TypeScriptOutFile />
    <TypeScriptOutDir />
    <TypeScriptGeneratesDeclarations>False</TypeScriptGeneratesDeclarations>
    <TypeScriptNoEmitOnError>True</TypeScriptNoEmitOnError>
    <TypeScriptSourceMap>True</TypeScriptSourceMap>
    <TypeScriptMapRoot />
    <TypeScriptSourceRoot />
  </PropertyGroup>

</Project>
